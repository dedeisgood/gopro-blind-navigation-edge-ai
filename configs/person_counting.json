{
  "task_name": "person_counting",
  "source": {
    "type": "synthetic",
    "frames": 120,
    "width": 640,
    "height": 360,
    "fps": 15
  },
  "model": {
    "backend": "dummy",
    "classes": ["person"]
  },
  "inference": {
    "resolution": [640, 360],
    "fps_limit": 15,
    "frame_skip": 0,
    "precision": "fp32",
    "device": "cpu"
  },
  "rules": [
    {
      "name": "crowd_alert",
      "type": "class_count",
      "class_name": "person",
      "operator": ">=",
      "threshold": 3
    }
  ],
  "output": {
    "run_dir": "runs/person_counting"
  }
}

