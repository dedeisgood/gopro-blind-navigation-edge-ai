{
  "task_name": "blind_obstacle_assist_gopro_video",
  "source": {
    "type": "video_file",
    "path": "assets/gopro_walk_sample.mp4",
    "max_frames": 300,
    "fps": 30
  },
  "model": {
    "weights": "yolov8n.pt",
    "device": "cpu",
    "confidence": 0.25,
    "obstacle_classes": [
      "person",
      "bicycle",
      "car",
      "motorcycle",
      "bus",
      "truck",
      "chair",
      "bench",
      "backpack",
      "suitcase",
      "stop sign"
    ]
  },
  "risk": {
    "center_region_ratio": 0.34,
    "medium_area_ratio": 0.05,
    "high_area_ratio": 0.18,
    "center_priority_boost": true
  },
  "output": {
    "run_dir": "runs/blind_obstacle_assist_gopro_video",
    "annotated_video": "annotated_obstacle_assist.mp4",
    "events": "events.jsonl",
    "metrics": "metrics.json"
  }
}

